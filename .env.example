# Database
# For local development (SQLite) - comment out when using Neon
# DATABASE_URL="file:./dev.db"

# For production / Neon (PostgreSQL) - uncomment and fill with your Neon URLs
# Get both from Neon Console → your project → Connect → copy Pooled (= DATABASE_URL), then turn OFF "Connection pooling" → copy (= DIRECT_URL)
# Replace YOUR_PASSWORD with the role password (from Neon Connect modal).
# On Vercel/serverless, add &connect_timeout=15 to DATABASE_URL if you see connection timeouts (Neon cold start).
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST_POOLER.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST_NO_POOLER.aws.neon.tech/neondb?sslmode=require"

# Authentication
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="change-this-to-a-strong-random-secret-in-production"

# Application
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# URL publique de l'app (requise pour la génération PDF sur Vercel). En prod : https://votre-domaine.vercel.app
# APP_URL="https://douma-dental-manager.vercel.app"

# PDF (Vercel) : optionnel. Si défini, les PDF sont générés via PDFShift (pas de Chromium sur le serveur).
# Créer un compte sur https://pdfshift.io et copier la clé API. Offre gratuite limitée.
# PDFSHIFT_API_KEY=""

# Admin User (for seed script)
# Set this when running seed in production
ADMIN_PASSWORD="change-this-in-production"

# E2E tests: do NOT set E2E_SEED in .env. It is set automatically by "npm run test:e2e".
# (E2E_SEED=1 forces known passwords in the seed)
# Comptes seed (dev / E2E) : admin@douma.com=password ; les autres=password123
# compta@douma.com, commercial@douma.com, stock@douma.com, livreur@douma.com, client@dental.com
# Magasinier (stock) → /magasinier ; Livreur (livreur@douma.com) → /delivery

# Exports Excel admin : limite optionnelle du nombre de lignes (ex. 20000). Non défini = pas de limite.
# EXPORT_MAX_ROWS=20000

# Optional: supprime l'avertissement "[baseline-browser-mapping] The data in this module is over two months old"
# (déjà géré par le script "npm run dev" via cross-env)
# BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true
